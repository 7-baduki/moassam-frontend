    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": ">=10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
